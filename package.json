{
  "name": "myra",
  "version": "0.2.1",
  "description": "MyRA - Native Electron desktop chat app wrapping Claude Code, Gemini CLI, and Opencode CLI",
  "main": "./out/main/index.js",
  "author": "Bertelsmann India Investment",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test --config tests/e2e/electron.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.web.json",
    "rebuild:electron": "cd node_modules/better-sqlite3 && node-gyp rebuild --target=33.4.11 --runtime=electron --dist-url=https://electronjs.org/headers/ --arch=x64 --release && cd ../.. && cp node_modules/better-sqlite3/build/Release/better_sqlite3.node node_modules/better-sqlite3/build/electron_better_sqlite3.node && npm rebuild better-sqlite3 && cp node_modules/better-sqlite3/build/Release/better_sqlite3.node node_modules/better-sqlite3/build/node_better_sqlite3.node",
    "postinstall": "node scripts/download-claude.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "node-cron": "^4.5.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.17",
    "electron": "^33.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
